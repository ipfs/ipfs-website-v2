---
const tracks = [
  {
    lang: 'JavaScript',
    primary: 'Helia',
    primaryBlurb: 'Modular · browsers + Node',
    alt: 'or one of the DASL libraries — even lighter.',
    cmd: 'npm install helia',
    link: 'helia.io',
  },
  {
    lang: 'Go',
    primary: 'Kubo',
    primaryBlurb: 'All-in-one · Swiss-army knife',
    alt: 'or Boxo for a modular, lightweight toolkit.',
    cmd: 'brew install ipfs',
    link: 'github.com/ipfs/kubo',
  },
  {
    lang: 'Specs',
    primary: 'specs.ipfs.tech',
    primaryBlurb: 'Implement independently · audit forks',
    alt: 'dasl.ing for the simple profile specs.',
    cmd: 'git clone specs.ipfs.tech',
    link: 'specs.ipfs.tech',
  },
];
---

<section class="relative overflow-hidden text-white" style="padding: 96px 32px 72px; background: var(--navy);">
  <svg class="absolute inset-0 w-full h-full" style="opacity: 0.4;" aria-hidden="true">
    <defs>
      <pattern id="ctadots" width="36" height="36" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.9" fill="rgba(107,196,206,0.2)" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#ctadots)" />
  </svg>
  <div class="relative mx-auto" style="max-width: 1240px;">
    <div style="margin-bottom: 40px; max-width: 820px;">
      <div class="mono" style="font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--ink-3); font-weight: 500; margin-bottom: 14px;">
        get started
      </div>
      <h2 style="margin: 0; font-size: 44px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.08;">
        Pick up the bits you need, and run.
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 16px;">
      {tracks.map((t) => (
        <div style="border: 1px solid rgba(107,196,206,0.25); border-radius: 12px; padding: 24px; background: rgba(255,255,255,0.03);">
          <div class="mono" style="font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--teal); margin-bottom: 14px; font-weight: 600;">
            For {t.lang}
          </div>
          <div style="font-size: 22px; font-weight: 600; color: #fff; margin-bottom: 4px;">
            → {t.primary}
          </div>
          <div style="font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 16px;">
            {t.primaryBlurb}
          </div>
          <div class="mono" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(107,196,206,0.18); padding: 10px 12px; border-radius: 6px; font-size: 13px; color: var(--teal); margin-bottom: 12px;">
            $ {t.cmd}
          </div>
          <div style="font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 14px;">{t.alt}</div>
          <a class="mono" style="font-size: 12px; color: var(--teal); text-decoration: none; font-weight: 500;">↗ {t.link}</a>
        </div>
      ))}
    </div>
  </div>
</section>
