---
import { categories } from '../data/stories';

const initials = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 3).toUpperCase();
const initials2 = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 2).toUpperCase();
---

<section style="padding: 96px 32px; background: var(--paper); border-top: 1px solid var(--hair);">
  <div class="mx-auto" style="max-width: 1240px;">
    <div style="margin-bottom: 56px; max-width: 820px;">
      <div class="mono" style="font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--ink-3); font-weight: 500; margin-bottom: 14px;">
        how are people using IPFS
      </div>
      <h2 style="margin: 0 0 12px; font-size: 44px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.08; color: var(--navy); text-wrap: balance;">
        Running in science labs, game studios, art vaults, and low earth orbit.
      </h2>
      <p style="margin: 0; font-size: 17px; color: var(--ink-2); max-width: 680px; line-height: 1.55;">
        Four jobs to be done, one set of building blocks. A sample of what teams have shipped once they stopped asking <em>where</em> the bytes live and started asking <em>what</em> the bytes are.
      </p>
    </div>

    {categories.map((cat, idx) => (
      <div class="usecase-category" style={`margin-top: ${idx === 0 ? '0' : '64px'};`}>
        <div class="usecase-head">
          <div>
            <div class="mono" style="font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--turq); font-weight: 600; margin-bottom: 10px;">
              0{idx + 1} · {cat.label}
            </div>
            <h3 style="margin: 0 0 8px; font-size: 26px; font-weight: 600; letter-spacing: -0.015em; color: var(--navy); line-height: 1.2;">
              {cat.job}
            </h3>
            <p style="margin: 0; font-size: 15px; color: var(--ink-2); line-height: 1.55; max-width: 520px;">
              {cat.framing}
            </p>
          </div>
        </div>

        <div class="usecase-grid">
          {cat.cases.map((card) => (
            <a class="story-card" style="text-decoration: none; color: inherit; background: var(--paper); border: 1px solid var(--line); border-radius: 12px; padding: 22px; display: flex; flex-direction: column; gap: 14px; cursor: pointer;">
              <div class="flex items-center" style="gap: 12px;">
                <div style={`width: 56px; height: 56px; border-radius: 10px; flex-shrink: 0; background: linear-gradient(135deg, hsl(${card.hue} 55% 45%) 0%, hsl(${(card.hue + 30) % 360} 55% 30%) 100%); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-weight: 600; font-size: 14px; letter-spacing: .03em; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);`}>
                  {initials(card.brand)}
                </div>
                <div class="mono" style="font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-3); font-weight: 600;">
                  {card.brand}
                </div>
              </div>
              <h4 style="margin: 0; font-size: 17px; font-weight: 600; color: var(--navy); line-height: 1.25; letter-spacing: -0.01em;">
                {card.title}
              </h4>
              <p style="margin: 0; font-size: 14px; color: var(--ink-2); line-height: 1.55; flex: 1;">
                {card.body}
              </p>

              {card.quote && (
                <figure style="margin: 4px 0 0; padding: 14px 14px 12px; background: var(--pearl); border-left: 2px solid var(--turq); border-radius: 4px; display: flex; flex-direction: column; gap: 10px;">
                  <blockquote style="margin: 0; font-size: 13px; color: var(--ink-2); line-height: 1.55; font-style: italic;">
                    “{card.quote.text}”
                  </blockquote>
                  <figcaption class="flex items-center" style="gap: 10px;">
                    <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--jade)); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 10px; font-weight: 600; flex-shrink: 0;">
                      {initials2(card.quote.who)}
                    </div>
                    <div>
                      <div style="font-size: 12px; font-weight: 600; color: var(--navy);">{card.quote.who}</div>
                      <div style="font-size: 11px; color: var(--ink-3);">{card.quote.role}</div>
                    </div>
                  </figcaption>
                </figure>
              )}

              <div class="mono flex justify-between" style="font-size: 12px; color: var(--turq); font-weight: 500; gap: 8px;">
                <span>↗ {card.linkLabel}</span>
                <span style="color: var(--ink-3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{card.link}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .usecase-head {
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--hair);
  }
  .usecase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .usecase-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .usecase-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .story-card {
    transition: transform .15s, box-shadow .15s, border-color .15s;
  }
  .story-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -18px rgba(7, 58, 83, 0.25);
    border-color: var(--turq);
  }
</style>
