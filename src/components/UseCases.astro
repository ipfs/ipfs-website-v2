---
import UseCasesTabs from './islands/UseCasesTabs.tsx';
---

<section id="usecases" class="usecases-section">
  <div class="usecases-inner">
    <div class="usecases-intro">
      <h2 class="usecases-title">
        Running in science labs, game studios, art vaults, and low earth orbit.
      </h2>
      <p class="usecases-lede">
        Anywhere data needs to be verifiable, CIDs tend to show up. A sample of what teams have built with the IPFS tools at the core.
      </p>
    </div>

    <UseCasesTabs client:visible />
  </div>
</section>

<style is:global>
  .usecases-section {
    padding: 96px 32px;
    background: var(--paper);
    border-top: 1px solid var(--hair);
  }
  .usecases-inner {
    margin: 0 auto;
    max-width: 1240px;
  }
  .usecases-intro {
    margin-bottom: 56px;
    max-width: 820px;
  }
  .usecases-title {
    margin: 0 0 12px;
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--navy);
    text-wrap: balance;
  }
  .usecases-lede {
    margin: 0;
    font-size: 17px;
    color: var(--ink-2);
    max-width: 680px;
    line-height: 1.55;
  }

  /* ── Tabs ─────────────────────────────────────────────────────────── */
  .uc-shell { position: relative; }

  .uc-tabs-rail {
    position: relative;
    display: flex;
    gap: 36px;
    border-bottom: 1px solid var(--hair);
    margin-bottom: 36px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .uc-tabs-rail::-webkit-scrollbar { display: none; }

  .uc-tab {
    position: relative;
    flex: 0 0 auto;
    background: transparent;
    border: 0;
    padding: 16px 0 18px;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: 10px;
    font: inherit;
    color: var(--ink-3);
    transition: color .25s ease;
  }
  .uc-tab:hover { color: var(--ink-2); }
  .uc-tab:focus-visible {
    outline: 2px solid var(--turq);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .uc-tab.is-active { color: var(--navy); }

  /* Pre-hydration: each active tab has its own underline so SSR looks right. */
  .uc-tab.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    background: var(--turq);
  }
  .uc-tabs-rail.is-hydrated .uc-tab.is-active::after { display: none; }

  .uc-tab-num {
    font-size: 11px;
    letter-spacing: .15em;
    font-weight: 600;
    color: var(--turq);
    opacity: .55;
    transition: opacity .25s ease;
  }
  .uc-tab.is-active .uc-tab-num { opacity: 1; }

  .uc-tab-label {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.005em;
    white-space: nowrap;
  }

  .uc-tab-count {
    font-size: 10px;
    letter-spacing: .12em;
    color: var(--ink-3);
    opacity: 0;
    transform: translateY(-1px);
    transition: opacity .25s ease;
  }
  .uc-tab.is-active .uc-tab-count { opacity: .7; }

  .uc-indicator {
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 2px;
    background: var(--turq);
    transition:
      transform .55s cubic-bezier(.65, 0, .35, 1),
      width .55s cubic-bezier(.65, 0, .35, 1);
    pointer-events: none;
    display: none;
    will-change: transform, width;
  }
  .uc-tabs-rail.is-hydrated .uc-indicator { display: block; }

  /* ── Panel ────────────────────────────────────────────────────────── */
  .uc-panel {
    animation: uc-panel-in .5s cubic-bezier(.2, .8, .2, 1) both;
  }
  @keyframes uc-panel-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .uc-head {
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--hair);
    max-width: 720px;
  }
  .uc-job {
    margin: 0 0 8px;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--navy);
    line-height: 1.2;
  }
  .uc-framing {
    margin: 0;
    font-size: 15px;
    color: var(--ink-2);
    line-height: 1.55;
    max-width: 560px;
  }

  /* ── Grid ─────────────────────────────────────────────────────────── */
  .uc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .uc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .uc-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Cards (preserved from prior design) ─────────────────────────── */
  .story-card {
    text-decoration: none;
    color: inherit;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    cursor: pointer;
    transition: transform .15s, box-shadow .15s, border-color .15s;
    animation: uc-card-in .55s cubic-bezier(.2, .8, .2, 1) both;
    animation-delay: calc(var(--i, 0) * 70ms + 100ms);
  }
  .story-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -18px rgba(7, 58, 83, 0.25);
    border-color: var(--turq);
  }
  @keyframes uc-card-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .story-card-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .story-card-mark {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    flex-shrink: 0;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: .03em;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
  }
  /* Logo variant: light tinted bg + brand-hued border, logo image fitted inside. */
  .story-card-mark-logo {
    box-shadow: none;
    padding: 8px;
  }
  .story-card-mark-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .story-card-brand {
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
  }
  .story-card-title {
    margin: 0;
    font-size: 17px;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .story-card-body {
    margin: 0;
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
    flex: 1;
  }
  .story-card-quote {
    margin: 4px 0 0;
    padding: 14px 14px 12px;
    background: var(--pearl);
    border-left: 2px solid var(--turq);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .story-card-quote-text {
    margin: 0;
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.55;
    font-style: italic;
  }
  .story-card-quote-cap {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .story-card-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--jade));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    flex-shrink: 0;
  }
  /* Photo variant: render the portrait image as the avatar disc. */
  .story-card-avatar-photo {
    object-fit: cover;
    background: var(--pearl);
  }
  .story-card-quote-who {
    font-size: 12px;
    font-weight: 600;
    color: var(--navy);
  }
  .story-card-quote-role {
    font-size: 11px;
    color: var(--ink-3);
  }
  .story-card-footer {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--turq);
    font-weight: 500;
    gap: 8px;
  }
  .story-card-link {
    color: var(--ink-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .usecases-section { padding: 72px 24px; }
    .usecases-title { font-size: 32px; }
    .uc-tabs-rail { gap: 24px; }
    .uc-job { font-size: 22px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .uc-panel,
    .story-card { animation: none !important; }
    .uc-indicator { transition: none !important; }
  }
</style>
