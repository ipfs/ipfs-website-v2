---
interface Props {
  size?: number;
  color?: string;
}
const { size = 22, color = 'currentColor' } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 32 32" aria-hidden="true">
  <polygon points="16,2 29,9.5 29,22.5 16,30 3,22.5 3,9.5"
    fill="none" stroke={color} stroke-width="1.6" stroke-linejoin="round" />
  <polygon points="16,8 24,12.5 24,19.5 16,24 8,19.5 8,12.5"
    fill={color} opacity="0.18" />
  <circle cx="16" cy="16" r="2.4" fill={color} />
  <circle cx="16" cy="8" r="1.4" fill={color} />
  <circle cx="16" cy="24" r="1.4" fill={color} />
  <circle cx="8" cy="12.5" r="1.4" fill={color} />
  <circle cx="24" cy="12.5" r="1.4" fill={color} />
  <circle cx="8" cy="19.5" r="1.4" fill={color} />
  <circle cx="24" cy="19.5" r="1.4" fill={color} />
</svg>
