---
import { categories } from '../data/stories';

// Brand logos for the trust strip — the subset of stories that ship a real mark.
const logos = [
  { src: '/brands/wikipedia.png', alt: 'Wikipedia' },
  { src: '/brands/snapshot.png', alt: 'Snapshot' },
  { src: '/brands/orcestra.svg', alt: 'ORCESTRA' },
  { src: '/brands/anytype.png', alt: 'Anytype' },
  { src: '/brands/weatherxm.png', alt: 'WeatherXM' },
  { src: '/brands/3s.png', alt: '3S Studios' },
];

// Single source of truth: lift every testimonial out of the use-case data so
// the cards below stay tight and the quotes live in one prominent place.
const quotes = categories.flatMap((c) =>
  c.cases
    .filter((x) => x.quote)
    .map((x) => ({ ...x.quote!, brand: x.brand })),
);

const initials = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 2).toUpperCase();
---

<section class="proof-section">
  <div class="proof-inner">
    <div class="mono proof-label">running in production at</div>
    <div class="proof-logos">
      {logos.map((l) => (
        <img class="proof-logo" src={l.src} alt={l.alt} loading="lazy" />
      ))}
    </div>

    <div class="proof-quotes">
      {quotes.map((q) => (
        <figure class="proof-quote">
          <blockquote class="proof-quote-text">“{q.text}”</blockquote>
          <figcaption class="proof-quote-cap">
            {q.photo ? (
              <img class="proof-avatar proof-avatar-photo" src={q.photo} alt={q.who} loading="lazy" />
            ) : (
              <div class="proof-avatar">{initials(q.who)}</div>
            )}
            <div>
              <div class="proof-quote-who">{q.who}</div>
              <div class="proof-quote-role">{q.role}</div>
            </div>
            <span class="mono proof-quote-brand">{q.brand}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .proof-section {
    padding: 64px 32px;
    background: var(--pearl);
    border-bottom: 1px solid var(--hair);
  }
  .proof-inner {
    margin: 0 auto;
    max-width: 1240px;
  }
  .proof-label {
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
    text-align: center;
    margin-bottom: 24px;
  }

  /* ── Logo strip ───────────────────────────────────────────────────── */
  .proof-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 40px 56px;
    margin-bottom: 56px;
  }
  .proof-logo {
    height: 30px;
    width: auto;
    max-width: 150px;
    object-fit: contain;
    /* Mute to a uniform tone so mismatched marks read as one strip. */
    filter: grayscale(1);
    opacity: .55;
    transition: filter .2s, opacity .2s;
  }
  .proof-logo:hover {
    filter: grayscale(0);
    opacity: 1;
  }

  /* ── Testimonials ─────────────────────────────────────────────────── */
  .proof-quotes {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .proof-quotes { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1080px) {
    .proof-quotes { grid-template-columns: repeat(3, 1fr); }
  }

  .proof-quote {
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .proof-quote-text {
    margin: 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink);
    letter-spacing: -0.005em;
    flex: 1;
  }
  .proof-quote-cap {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .proof-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--teal), var(--jade));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
  }
  .proof-avatar-photo {
    object-fit: cover;
    background: var(--pearl);
  }
  .proof-quote-who {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
  }
  .proof-quote-role {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.3;
  }
  .proof-quote-brand {
    margin-left: auto;
    align-self: flex-start;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--turq);
    font-weight: 600;
  }

  @media (max-width: 760px) {
    .proof-section { padding: 48px 24px; }
    .proof-logos { gap: 28px 36px; margin-bottom: 40px; }
    .proof-logo { height: 24px; }
  }
</style>
