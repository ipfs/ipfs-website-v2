---
// Locked to the "buildingBlocks" tagline from the prototype's TAGLINES map.
const tagline = {
  pre: 'Building Blocks For ',
  hl: 'a Better Web',
  post: '.',
  sub: 'A constellation of tools for content addressing.',
};
---

<section class="relative overflow-hidden text-white" style="background: var(--grad);">
  <svg class="absolute inset-0 w-full h-full" style="opacity: 0.5;" aria-hidden="true">
    <defs>
      <pattern id="herodots" width="32" height="32" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="1" fill="rgba(255,255,255,0.18)" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#herodots)" />
  </svg>
  <div class="relative mx-auto" style="max-width: 1240px; padding: 96px 32px 72px;">
    <h1 class="hero-h1" style="font-weight: 600; letter-spacing: -0.025em; margin: 0 0 28px; line-height: 1.04; max-width: 980px; text-wrap: balance;">
      {tagline.pre}<span class="mono" style="color: var(--teal); font-weight: 500; border-bottom: 4px solid var(--teal); padding-bottom: 2px;">{tagline.hl}</span>{tagline.post}
    </h1>
    <p style="font-size: 20px; color: rgba(255,255,255,0.85); max-width: 720px; margin: 0 0 36px; line-height: 1.5;">
      {tagline.sub}
    </p>
    <div class="flex flex-wrap items-center" style="gap: 12px;">
      <button class="mono" style="background: var(--teal); color: var(--navy); border: none; padding: 14px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; letter-spacing: .01em;">$ npm install helia</button>
      <button style="background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.4); padding: 13px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer;">Read the spec →</button>
      <span class="mono" style="font-size: 12px; color: rgba(255,255,255,0.6); margin-left: 6px;">
        open-source · v0.26
      </span>
    </div>
  </div>
</section>

<style>
  .hero-h1 {
    font-size: clamp(40px, 5.2vw, 72px);
  }
</style>
