---
// Locked to the "buildingBlocks" tagline from the prototype's TAGLINES map.
const tagline = {
  pre: 'Building Blocks For ',
  hl: 'a Better Web',
  post: '.',
  sub: 'A constellation of tools for content addressing.',
};

// Deterministic constellation mesh. Positions come from a jittered grid
// across a 1240x560 viewBox; edges connect each node to its 2 nearest
// neighbors. Generated at build time so there's no client-side cost.
const VB_W = 1240;
const VB_H = 560;
const COLS = 14;
const ROWS = 7;

// Seeded PRNG (mulberry32) so the layout is stable across builds.
function rng(seed: number) {
  let s = seed >>> 0;
  return () => {
    s = (s + 0x6d2b79f5) >>> 0;
    let t = s;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = rng(0xC1D);

const cellW = VB_W / COLS;
const cellH = VB_H / ROWS;
type Node = { x: number; y: number; r: number; accent: boolean };
const nodes: Node[] = [];
for (let i = 0; i < COLS; i++) {
  for (let j = 0; j < ROWS; j++) {
    // Drop ~15% of cells for an irregular, natural look.
    if (rand() < 0.15) continue;
    const jitterX = (rand() - 0.5) * cellW * 0.7;
    const jitterY = (rand() - 0.5) * cellH * 0.7;
    nodes.push({
      x: i * cellW + cellW / 2 + jitterX,
      y: j * cellH + cellH / 2 + jitterY,
      r: 1.2 + rand() * 1.4,
      accent: rand() < 0.12,
    });
  }
}

// Build edges: each node connects to its 2 nearest neighbors. Dedupe pairs.
const edgeSet = new Set<string>();
type Edge = { a: Node; b: Node; d: number };
const edges: Edge[] = [];
for (let i = 0; i < nodes.length; i++) {
  const dists = nodes
    .map((n, k) => ({ k, d: Math.hypot(n.x - nodes[i].x, n.y - nodes[i].y) }))
    .filter((e) => e.k !== i)
    .sort((a, b) => a.d - b.d)
    .slice(0, 2);
  for (const { k, d } of dists) {
    const key = i < k ? `${i}-${k}` : `${k}-${i}`;
    if (edgeSet.has(key)) continue;
    edgeSet.add(key);
    edges.push({ a: nodes[i], b: nodes[k], d });
  }
}
---

<section class="relative overflow-hidden text-white" style="background: var(--grad);">
  <svg
    class="absolute inset-0 w-full h-full"
    viewBox={`0 0 ${VB_W} ${VB_H}`}
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      {/* Radial mask: opaque mesh at edges, fading toward the headline anchor (left-center) for legibility. */}
      <radialGradient id="heromask" cx="28%" cy="55%" r="65%">
        <stop offset="0%" stop-color="#000" stop-opacity="0" />
        <stop offset="55%" stop-color="#fff" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#fff" stop-opacity="1" />
      </radialGradient>
      <mask id="heromaskApply">
        <rect width="100%" height="100%" fill="url(#heromask)" />
      </mask>
    </defs>
    <g mask="url(#heromaskApply)" class="mesh">
      {edges.map(({ a, b, d }) => {
        // Per-edge stagger: long, slow breathe.
        const dur = (4 + rand() * 4).toFixed(2);
        const delay = (-rand() * 8).toFixed(2);
        const base = Math.max(0.15, 1 - d / 220);
        return (
          <line
            x1={a.x}
            y1={a.y}
            x2={b.x}
            y2={b.y}
            stroke="rgba(255,255,255,0.22)"
            stroke-width="0.8"
            class="edge"
            style={`opacity:${base};--dur:${dur}s;--delay:${delay}s;--peak:${base.toFixed(2)};--trough:${(base * 0.35).toFixed(2)}`}
          />
        );
      })}
      {nodes.map((n) => {
        // Per-node stagger: faster shimmer than edges.
        const dur = (2 + rand() * 3).toFixed(2);
        const delay = (-rand() * 5).toFixed(2);
        return (
          <circle
            cx={n.x}
            cy={n.y}
            r={n.r}
            fill={n.accent ? 'var(--teal)' : 'rgba(255,255,255,0.85)'}
            class="node"
            style={`--dur:${dur}s;--delay:${delay}s`}
          />
        );
      })}
    </g>
  </svg>
  <div class="relative mx-auto" style="max-width: 1240px; padding: 96px 32px 72px;">
    <h1 class="hero-h1" style="font-weight: 600; letter-spacing: -0.025em; margin: 0 0 28px; line-height: 1.04; max-width: 980px; text-wrap: balance;">
      {tagline.pre}<span class="mono" style="color: var(--teal); font-weight: 500; border-bottom: 4px solid var(--teal); padding-bottom: 2px;">{tagline.hl}</span>{tagline.post}
    </h1>
    <p style="font-size: 20px; color: rgba(255,255,255,0.85); max-width: 720px; margin: 0 0 36px; line-height: 1.5;">
      {tagline.sub}
    </p>
    <div class="flex flex-wrap items-center" style="gap: 12px;">
      <button class="mono" style="background: var(--teal); color: var(--navy); border: none; padding: 14px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; letter-spacing: .01em;">$ npm install helia</button>
      <button style="background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.4); padding: 13px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer;">Read the spec →</button>
      <span class="mono" style="font-size: 12px; color: rgba(255,255,255,0.6); margin-left: 6px;">
        open-source · v0.26
      </span>
    </div>
  </div>
</section>

<style>
  .hero-h1 {
    font-size: clamp(40px, 5.2vw, 72px);
  }
  .mesh {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation: meshDrift 90s ease-in-out infinite;
  }
  .node {
    animation: nodeTwinkle var(--dur) ease-in-out var(--delay) infinite;
  }
  .edge {
    animation: edgeBreathe var(--dur) ease-in-out var(--delay) infinite;
  }
  @keyframes nodeTwinkle {
    0%, 100% { opacity: 0.45; }
    50%      { opacity: 1; }
  }
  @keyframes edgeBreathe {
    0%, 100% { opacity: var(--trough); }
    50%      { opacity: var(--peak); }
  }
  @keyframes meshDrift {
    0%   { transform: rotate(-0.6deg) translate(-6px, -4px); }
    50%  { transform: rotate(0.6deg)  translate(6px, 4px); }
    100% { transform: rotate(-0.6deg) translate(-6px, -4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .node, .edge, .mesh { animation: none; }
  }
</style>
