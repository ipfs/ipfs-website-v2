---
import SectionHeader from './SectionHeader.astro';
import FoundationsIsland from './islands/Foundations.tsx';
---

<section style="padding: 96px 32px; background: var(--paper);">
  <div class="mx-auto" style="max-width: 1240px;">
    <SectionHeader
      label="three commitments"
      title="Not a platform to migrate to. A property you add."
      kicker="Every tool in the IPFS constellation agrees on three principles. Pick one to see it in motion — and grab the building blocks you need."
    />
    <FoundationsIsland client:visible />
  </div>
</section>
