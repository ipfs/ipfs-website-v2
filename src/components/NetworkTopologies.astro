---
import SectionHeader from './SectionHeader.astro';
---

<section style="padding: 96px 32px; background: var(--pearl); border-top: 1px solid var(--hair);">
  <div class="mx-auto" style="max-width: 1240px;">
    <SectionHeader
      title="Network models"
      kicker="The same content-addressing model works on the open internet and in closed private networks. Same CIDs, different routing."
    />
    <div class="topo-grid">

      <!-- Public / open network -->
      <div class="topo-card">
        <div class="topo-diagram" aria-hidden="true">
          <!-- Hexagon: center (140,93) radius 68
               N0(140,25) N1(199,59) N2(199,127) N3(140,161) N4(81,127) N5(81,59)
               Edges: 6 perimeter + 3 long diagonals (each node has 3 connections) -->
          <svg viewBox="0 0 280 180" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
            <!-- Perimeter edges -->
            <line class="t-line" x1="140" y1="25"  x2="199" y2="59"/>
            <line class="t-line" x1="199" y1="59"  x2="199" y2="127"/>
            <line class="t-line" x1="199" y1="127" x2="140" y2="161"/>
            <line class="t-line" x1="140" y1="161" x2="81"  y2="127"/>
            <line class="t-line" x1="81"  y1="127" x2="81"  y2="59"/>
            <line class="t-line" x1="81"  y1="59"  x2="140" y2="25"/>
            <!-- Long diagonals (slightly dimmer) -->
            <line class="t-line t-line--dim" x1="140" y1="25"  x2="140" y2="161"/>
            <line class="t-line t-line--dim" x1="199" y1="59"  x2="81"  y2="127"/>
            <line class="t-line t-line--dim" x1="199" y1="127" x2="81"  y2="59"/>

            <!-- Nodes (all equal peers) -->
            <circle class="t-node" cx="140" cy="25"  r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <circle class="t-node" cx="199" cy="59"  r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="0.43s"/>
            </circle>
            <circle class="t-node" cx="199" cy="127" r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="0.87s"/>
            </circle>
            <circle class="t-node" cx="140" cy="161" r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="1.3s"/>
            </circle>
            <circle class="t-node" cx="81"  cy="127" r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="1.73s"/>
            </circle>
            <circle class="t-node" cx="81"  cy="59"  r="10">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite" begin="2.17s"/>
            </circle>

            <!-- Traveling dots — one per edge, staggered 0.33 s -->
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="140;199;140" dur="3s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="cy" values="25;59;25"    dur="3s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="199;199;199" dur="3s" repeatCount="indefinite" begin="0.33s"/>
              <animate attributeName="cy" values="59;127;59"   dur="3s" repeatCount="indefinite" begin="0.33s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="0.33s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="199;140;199" dur="3s" repeatCount="indefinite" begin="0.67s"/>
              <animate attributeName="cy" values="127;161;127" dur="3s" repeatCount="indefinite" begin="0.67s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="0.67s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="140;81;140"  dur="3s" repeatCount="indefinite" begin="1s"/>
              <animate attributeName="cy" values="161;127;161" dur="3s" repeatCount="indefinite" begin="1s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="1s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="81;81;81"   dur="3s" repeatCount="indefinite" begin="1.33s"/>
              <animate attributeName="cy" values="127;59;127" dur="3s" repeatCount="indefinite" begin="1.33s"/>
              <animate attributeName="opacity" values="0;1;0" dur="3s" repeatCount="indefinite" begin="1.33s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="81;140;81" dur="3s" repeatCount="indefinite" begin="1.67s"/>
              <animate attributeName="cy" values="59;25;59"  dur="3s" repeatCount="indefinite" begin="1.67s"/>
              <animate attributeName="opacity" values="0;1;0" dur="3s" repeatCount="indefinite" begin="1.67s"/>
            </circle>
            <!-- Diagonal dots -->
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="140;140;140" dur="3s" repeatCount="indefinite" begin="2s"/>
              <animate attributeName="cy" values="25;161;25"   dur="3s" repeatCount="indefinite" begin="2s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="2s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="199;81;199"  dur="3s" repeatCount="indefinite" begin="2.33s"/>
              <animate attributeName="cy" values="59;127;59"   dur="3s" repeatCount="indefinite" begin="2.33s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="2.33s"/>
            </circle>
            <circle class="t-dot" r="3.5">
              <animate attributeName="cx" values="199;81;199"  dur="3s" repeatCount="indefinite" begin="2.67s"/>
              <animate attributeName="cy" values="127;59;127"  dur="3s" repeatCount="indefinite" begin="2.67s"/>
              <animate attributeName="opacity" values="0;1;0"  dur="3s" repeatCount="indefinite" begin="2.67s"/>
            </circle>
          </svg>
        </div>
        <div class="topo-body">
          <span class="topo-badge topo-badge--public">Public</span>
          <p class="topo-desc">Nodes discover peers via the Amino DHT and IPNI. Any compliant node can join and find content, no coordination required.</p>
        </div>
      </div>

      <!-- Private network -->
      <div class="topo-card">
        <div class="topo-diagram" aria-hidden="true">
          <svg viewBox="0 0 280 180" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
            <!-- Rotating boundary ring -->
            <circle class="p-boundary" cx="140" cy="95" r="68">
              <animateTransform attributeName="transform" type="rotate"
                                from="0 140 95" to="360 140 95"
                                dur="18s" repeatCount="indefinite"/>
            </circle>

            <!-- Mesh lines (drawn before nodes) -->
            <!-- Square edges: T(140,27)–R(208,95)–B(140,163)–L(72,95)–T -->
            <line class="p-line" x1="140" y1="27" x2="208" y2="95"/>
            <line class="p-line" x1="208" y1="95" x2="140" y2="163"/>
            <line class="p-line" x1="140" y1="163" x2="72" y2="95"/>
            <line class="p-line" x1="72" y1="95" x2="140" y2="27"/>
            <!-- Diagonals (lighter) -->
            <line class="p-line p-line--dim" x1="140" y1="27" x2="140" y2="163"/>
            <line class="p-line p-line--dim" x1="72" y1="95" x2="208" y2="95"/>

            <!-- Nodes -->
            <circle class="p-node" cx="140" cy="27" r="9">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.2s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <circle class="p-node" cx="208" cy="95" r="9">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.2s" repeatCount="indefinite" begin="0.55s"/>
            </circle>
            <circle class="p-node" cx="140" cy="163" r="9">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.2s" repeatCount="indefinite" begin="1.1s"/>
            </circle>
            <circle class="p-node" cx="72" cy="95" r="9">
              <animate attributeName="opacity" values="1;0.5;1" dur="2.2s" repeatCount="indefinite" begin="1.65s"/>
            </circle>

            <!-- Lock icon at center -->
            <path class="p-lock-shackle" d="M 133 95 A 7 7 0 0 1 147 95"/>
            <rect class="p-lock-body" x="130" y="95" width="20" height="15" rx="3"/>
            <circle class="p-lock-key" cx="140" cy="102" r="2.5"/>
            <rect class="p-lock-key" x="138.5" y="102" width="3" height="5" rx="1"/>

            <!-- Traveling dots around the ring -->
            <!-- T → R -->
            <circle class="p-dot" r="3.5">
              <animate attributeName="cx" values="140;208;140" dur="3.5s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="cy" values="27;95;27" dur="3.5s" repeatCount="indefinite" begin="0s"/>
              <animate attributeName="opacity" values="0;0.9;0" dur="3.5s" repeatCount="indefinite" begin="0s"/>
            </circle>
            <!-- R → B -->
            <circle class="p-dot" r="3.5">
              <animate attributeName="cx" values="208;140;208" dur="3.5s" repeatCount="indefinite" begin="0.875s"/>
              <animate attributeName="cy" values="95;163;95" dur="3.5s" repeatCount="indefinite" begin="0.875s"/>
              <animate attributeName="opacity" values="0;0.9;0" dur="3.5s" repeatCount="indefinite" begin="0.875s"/>
            </circle>
            <!-- B → L -->
            <circle class="p-dot" r="3.5">
              <animate attributeName="cx" values="140;72;140" dur="3.5s" repeatCount="indefinite" begin="1.75s"/>
              <animate attributeName="cy" values="163;95;163" dur="3.5s" repeatCount="indefinite" begin="1.75s"/>
              <animate attributeName="opacity" values="0;0.9;0" dur="3.5s" repeatCount="indefinite" begin="1.75s"/>
            </circle>
            <!-- L → T -->
            <circle class="p-dot" r="3.5">
              <animate attributeName="cx" values="72;140;72" dur="3.5s" repeatCount="indefinite" begin="2.625s"/>
              <animate attributeName="cy" values="95;27;95" dur="3.5s" repeatCount="indefinite" begin="2.625s"/>
              <animate attributeName="opacity" values="0;0.9;0" dur="3.5s" repeatCount="indefinite" begin="2.625s"/>
            </circle>
          </svg>
        </div>
        <div class="topo-body">
          <span class="topo-badge topo-badge--private">Private</span>
          <p class="topo-desc">All peers share a swarm key. Routing and transfer stay within the closed network. Nothing routes in or out without it.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .topo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 700px) {
    .topo-grid { grid-template-columns: 1fr; }
  }

  .topo-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
  }

  .topo-diagram {
    aspect-ratio: 14 / 9;
    background: var(--pearl);
    border-bottom: 1px solid var(--line);
    padding: 8px;
  }
  .topo-diagram svg { display: block; width: 100%; height: 100%; }

  .topo-body {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .topo-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    width: fit-content;
    border: 1px solid;
  }
  .topo-badge--public { color: var(--turq); border-color: var(--turq); background: var(--pearl); }
  .topo-badge--private { color: var(--jade); border-color: var(--jade); background: var(--pearl); }

  .topo-desc {
    margin: 0;
    font-size: 15px;
    color: var(--ink-2);
    line-height: 1.6;
  }

  /* Public network SVG classes */
  .t-line { stroke: var(--line); stroke-width: 1.5; fill: none; }
  .t-line--dim { opacity: 0.45; }
  .t-node { fill: var(--paper); stroke: var(--turq); stroke-width: 1.5; }
  .t-dot { fill: var(--turq); }

  /* Private network SVG classes */
  .p-boundary { fill: none; stroke: var(--jade); stroke-width: 1.5; stroke-dasharray: 6 4; opacity: 0.4; }
  .p-line { stroke: var(--line); stroke-width: 1.5; fill: none; }
  .p-line--dim { opacity: 0.45; }
  .p-node { fill: var(--paper); stroke: var(--jade); stroke-width: 1.5; }
  .p-dot { fill: var(--jade); }
  .p-lock-shackle { fill: none; stroke: var(--jade); stroke-width: 2; stroke-linecap: round; }
  .p-lock-body { fill: var(--pearl); stroke: var(--jade); stroke-width: 1.5; }
  .p-lock-key { fill: var(--jade); }

  @media (prefers-reduced-motion: reduce) {
    .p-boundary { animation: none; }
  }
</style>
