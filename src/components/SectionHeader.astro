---
interface Props {
  label?: string;
  title: string;
  kicker?: string | null;
}
const { label, title, kicker } = Astro.props;
---

<div style="margin-bottom: 40px; max-width: 820px;">
  {label && (
    <div class="retro-label" style="font-size: var(--text-ui); color: var(--ink-3); margin-bottom: 14px;">
      {label}
    </div>
  )}
  <h2 style="margin: 0 0 12px; font-size: var(--text-h2); font-weight: 600; letter-spacing: -0.02em; line-height: 1.08; color: var(--navy); text-wrap: balance;">
    {title}
  </h2>
  {kicker && (
    <p style="margin: 0; font-size: var(--text-lead); color: var(--ink-2); max-width: 680px; line-height: 1.55;">
      {kicker}
    </p>
  )}
</div>
