---
import { stories, testimonials } from '../data/stories';

const initials = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 3).toUpperCase();
const initials2 = (name: string) =>
  name.split(/\s+/).map((w) => w[0]).join('').slice(0, 2).toUpperCase();
---

<section style="padding: 96px 32px; background: var(--paper); border-top: 1px solid var(--hair);">
  <div class="mx-auto" style="max-width: 1240px;">
    <div style="margin-bottom: 40px; max-width: 820px;">
      <div class="mono" style="font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--ink-3); font-weight: 500; margin-bottom: 14px;">
        real-world stories
      </div>
      <h2 style="margin: 0 0 12px; font-size: 44px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.08; color: var(--navy); text-wrap: balance;">
        Running in science labs, game studios, art vaults — and low earth orbit.
      </h2>
      <p style="margin: 0; font-size: 17px; color: var(--ink-2); max-width: 680px; line-height: 1.55;">
        A sample of what teams have done once they stopped asking <em>where</em> the bytes live
        and started asking <em>what</em> the bytes are.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" style="gap: 16px;">
      {stories.map((card) => (
        <a class="story-card" style="text-decoration: none; color: inherit; background: var(--paper); border: 1px solid var(--line); border-radius: 12px; padding: 22px; display: flex; flex-direction: column; gap: 14px; cursor: pointer;">
          <div class="flex items-center" style="gap: 12px;">
            <div style={`width: 56px; height: 56px; border-radius: 10px; flex-shrink: 0; background: linear-gradient(135deg, hsl(${card.hue} 55% 45%) 0%, hsl(${(card.hue + 30) % 360} 55% 30%) 100%); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-weight: 600; font-size: 14px; letter-spacing: .03em; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);`}>
              {initials(card.brand)}
            </div>
            <div class="mono" style="font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-3); font-weight: 600;">
              {card.brand}
            </div>
          </div>
          <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--navy); line-height: 1.25; letter-spacing: -0.01em;">
            {card.title}
          </h3>
          <p style="margin: 0; font-size: 14px; color: var(--ink-2); line-height: 1.55; flex: 1;">
            {card.body}
          </p>
          <div class="mono flex justify-between" style="font-size: 12px; color: var(--turq); font-weight: 500;">
            <span>↗ {card.linkLabel}</span>
            <span style="color: var(--ink-3);">{card.link}</span>
          </div>
        </a>
      ))}
    </div>

    <div style="margin-top: 72px; margin-bottom: 36px;">
      <h3 style="margin: 0 0 6px; font-size: 28px; font-weight: 600; color: var(--navy); letter-spacing: -0.01em;">
        What builders say
      </h3>
      <div class="mono" style="font-size: 12px; color: var(--ink-3);">
        {testimonials.length} voices · more at <span style="color: var(--turq);">discuss.ipfs.tech</span>
      </div>
    </div>
    <div class="testimonial-masonry">
      {testimonials.map((t) => (
        <figure class="testimonial-card" style="margin: 0 0 16px; background: var(--paper); border: 1px solid var(--line); border-radius: 12px; padding: 24px; display: flex; flex-direction: column; gap: 16px; break-inside: avoid;">
          <div class="mono" style="font-size: 32px; color: var(--turq); line-height: 0.8; font-weight: 600;">"</div>
          <blockquote style="margin: 0; font-size: 15px; color: var(--ink-2); line-height: 1.6;">
            {t.quote}
          </blockquote>
          <figcaption class="flex items-center" style="gap: 12px; margin-top: auto;">
            <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--jade)); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-size: 12px; font-weight: 600; flex-shrink: 0;">
              {initials2(t.who)}
            </div>
            <div>
              <div style="font-size: 14px; font-weight: 600; color: var(--navy);">{t.who}</div>
              <div style="font-size: 12px; color: var(--ink-3);">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .story-card {
    transition: transform .15s, box-shadow .15s, border-color .15s;
  }
  .story-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px -18px rgba(7, 58, 83, 0.25);
    border-color: var(--turq);
  }
  .testimonial-masonry {
    column-count: 1;
    column-gap: 16px;
  }
  @media (min-width: 640px) {
    .testimonial-masonry { column-count: 2; }
  }
  @media (min-width: 1024px) {
    .testimonial-masonry { column-count: 3; }
  }
</style>
