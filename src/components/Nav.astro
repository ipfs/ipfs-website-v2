---
import Logomark from './Logomark.astro';
---

<nav class="sticky top-0 z-20 backdrop-blur-md border-b" style="background: rgba(255,255,255,0.92); border-color: var(--hair);">
  <div class="mx-auto flex items-center justify-between" style="max-width: 1240px; padding: 14px 32px;">
    <div class="flex items-center" style="gap: 10px; color: var(--navy);">
      <Logomark size={24} color="var(--navy)" />
      <span class="mono" style="font-weight: 600; font-size: 15px; letter-spacing: .02em;">IPFS</span>
    </div>
    <div class="hidden md:flex" style="gap: 28px; font-size: 14px; color: var(--ink-2);">
      <a class="nav-link">Docs</a>
      <a class="nav-link">Specs</a>
      <a class="nav-link">Tools</a>
      <a class="nav-link">Community</a>
      <a class="nav-link">Blog</a>
    </div>
    <div class="flex items-center" style="gap: 10px;">
      <a class="nav-link hidden sm:inline" style="font-size: 13px;">github ↗</a>
      <button class="mono" style="background: var(--navy); color: #fff; border: none; padding: 8px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; white-space: nowrap; flex-shrink: 0;">$ install</button>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    text-decoration: none;
    color: var(--ink-2);
    cursor: pointer;
    font-weight: 500;
  }
</style>
